# Optional. Copy to .env.local only if you need to override a default —
# `npm install && npm run dev` works with zero env setup out of the box.
# All variables are NEXT_PUBLIC_* — this dashboard is a read-only API
# consumer and never holds secrets.

# Base URL of the backend REST API (see docs/api-contract.md). Leave unset
# to use this app's own built-in mock routes under src/app/api/*, which read
# from the plain, hand-editable JSON files in src/data/ — edit those files
# directly to plug in your own numbers. Once a real backend exists, point
# this at it instead, e.g. https://api.gh2028watch.example.com/api.
# NEXT_PUBLIC_API_BASE_URL=

# Minimum polling interval in milliseconds. Constraint from the spec: never
# auto-refresh faster than 5 minutes, to respect API rate limits and avoid
# appearing to manipulate perception via rapid updates. Hard-floored in
# src/lib/hooks/index.ts regardless of what this is set to — see
# MIN_REFRESH_INTERVAL_MS there.
NEXT_PUBLIC_REFRESH_INTERVAL_MS=300000

# Static link to the versioned public methodology page (spec Component 6 —
# "maintain a public, versioned methodology page"). Shown in the persistent
# MethodologyModal on every view.
NEXT_PUBLIC_METHODOLOGY_URL=https://example.com/gh2028watch/methodology

# Current model version string, shown in the methodology modal and on every
# forecast card footnote so followers can tell when the model itself changed
# vs. just the data.
NEXT_PUBLIC_MODEL_VERSION=v0.1.0-phase0

# Environment label shown in a small banner during Phase 0-3 (internal
# monitoring) so nobody mistakes a dev/staging deployment for the live
# public dashboard. Set to "production" only for the Phase 4+ public launch.
NEXT_PUBLIC_DEPLOY_ENV=development
