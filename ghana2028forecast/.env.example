# Copy to .env and fill in. Never commit the real .env file.

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/ghana2028

# --- X (Twitter) API v2 ---
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- Meta Content Library (academic/researcher access) ---
META_CONTENT_LIBRARY_TOKEN=

# --- Publishing (Metricool) ---
METRICOOL_API_TOKEN=
METRICOOL_USER_ID=
METRICOOL_BLOG_ID=

# --- Content generation ---
ANTHROPIC_API_KEY=

# --- GhanaNLP Khaya translation ---
KHAYA_API_KEY=

# --- Runtime ---
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=INFO
REQUIRE_HUMAN_APPROVAL=true   # keep true through Phase 1-3 per roadmap
